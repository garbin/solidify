{
  "name": "solidify.js",
  "version": "0.1.0",
  "description": "Solidify: Fast, solid, and seamless. Your all-in-one Node.js framework for CLI, ORM, REST, and GraphQL.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib/*.js": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ]; then husky; fi",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "npm run build && c8 ava",
    "test:contract": "npm run build && ava \"test/contract/**/*.test.js\"",
    "test:matrix": "npm run build && ava \"test/matrix/**/*.test.js\"",
    "test:types": "npm run build && tsc -p test/types/tsconfig.json --noEmit",
    "coverage": "npm run test && c8 report --reporter=text-lcov > coverage/codecov.lcov"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,mts}": [
      "npm run lint -- --write"
    ]
  },
  "dependencies": {
    "@fastify/request-context": "^6.2.1",
    "@graphql-tools/schema": "^10.0.29",
    "commander": "^14.0.2",
    "dataloader": "^2.2.3",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "graphql-scalars": "^1.25.0",
    "http-content-range-format": "^1.0.0",
    "http-errors": "^2.0.1",
    "inflected": "^2.1.0",
    "lodash-es": "^4.17.23",
    "mercurius": "^16.8.0",
    "objection": "^3.1.5",
    "range-specifier-parser": "^1.0.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@faker-js/faker": "^10.1.0",
    "@types/http-errors": "^2.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.18.6",
    "ava": "^6.4.1",
    "c8": "^10.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "mercurius-integration-testing": "^9.0.1",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "sqlite3": "^5.1.7",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garbin/solidify.git"
  },
  "homepage": "https://github.com/garbin/solidify",
  "bugs": {
    "url": "https://github.com/garbin/solidify/issues"
  },
  "keywords": [
    "fastify",
    "web",
    "framework",
    "rest",
    "graphql",
    "objection",
    "orm",
    "api",
    "nodejs"
  ],
  "author": "Garbin Huang <garbinh@gmail.com>",
  "license": "MIT"
}
